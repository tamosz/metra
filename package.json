{
  "name": "royals-balance",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "description": "Royals class balance simulator",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dump-sheet": "tsx scripts/dump-sheet.ts",
    "simulate": "tsx src/cli.ts",
    "type-check": "tsc --noEmit",
    "type-check:web": "cd web && tsc --noEmit",
    "type-check:all": "tsc --noEmit && cd web && tsc --noEmit",
    "setup": "git config core.hooksPath .githooks",
    "vercel-build": "cd web && npm install && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
