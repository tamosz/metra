{
  "name": "maple-balance",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "description": "MapleRoyals class balance simulator",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dump-sheet": "tsx scripts/dump-sheet.ts",
    "simulate": "tsx src/cli.ts",
    "type-check": "tsc --noEmit",
    "type-check:web": "cd web && tsc --noEmit",
    "type-check:all": "tsc --noEmit && cd web && tsc --noEmit",
    "setup": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "tsx": "^4.7.0"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
