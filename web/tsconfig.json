{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@engine/*": ["../src/*"],
      "@data/*": ["../data/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "../src/**/*"],
  "exclude": [
    "node_modules",
    "../src/cli.ts",
    "../src/cli.test.ts",
    "../src/sheets/**",
    "../src/data/loader.ts",
    "../src/data/loader.test.ts",
    "../src/integration.test.ts"
  ]
}
